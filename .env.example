# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urban_mobility

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379

# Weather API Key (OpenWeatherMap)
# Get your free key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Mapbox Token (optional, for advanced mapping)
# Get your token at: https://account.mapbox.com/
MAPBOX_TOKEN=your_mapbox_token_here

# Traffic API Keys (optional)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
TOMTOM_API_KEY=your_tomtom_key_here
HERE_API_KEY=your_here_key_here

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Server Configuration
API_HOST=0.0.0.0
API_PORT=5000

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Cache Settings
CACHE_TTL_SECONDS=300

# Data Update Intervals (seconds)
TRAFFIC_UPDATE_INTERVAL=300
WEATHER_UPDATE_INTERVAL=600
CRIME_UPDATE_INTERVAL=3600